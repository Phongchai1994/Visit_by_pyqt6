QDialog#prisoner_list_popup QLabel#Qlabel_lbl_none{
    color: #b71c1c;
}

/*########  add relative ###########*/

QPushButton#Qpush_input_btn_read_card{
    font-family: 'Sarabun', Arial, sans-serif;
    background-color: #1a237e;
    color: #fff;
    border: 2px solid #3949ab;
    border-radius: 6px;
    padding: 8px 18px;
    font-weight: bold;
    font-size: 14px;
    width: 160px;
}
QPushButton#Qpush_input_btn_read_card:hover{
    background-color: #3949ab;
    border-color: #1a237e;
    color: #e3f2fd
}
QPushButton#Qpush_input_btn_read_card:pressed{
    background-color: #0d133d;    
    border-color: #1a237e;
    color: #b0bec5;
}
QPushButton#Qpush_btn_save {
    background-color: #1976d2;      /* น้ำเงินสด */
    color: #fff;
    border: 2px solid #1565c0;
    border-radius: 6px;
    padding: 8px 24px;
    font-weight: bold;
    font-size: 15px;
    min-width: 120px;
}
QPushButton#Qpush_btn_save:hover {
    background-color: #1565c0;
    border-color: #1976d2;
    color: #e3f2fd;
}
QPushButton#Qpush_btn_save:pressed {
    background-color: #0d47a1;
    border-color: #1565c0;
    color: #b0bec5;
}

QPushButton#Qpush_btn_close {
    background-color: #e0e0e0;      /* เทาอ่อน */
    color: #333;
    border: 2px solid #bdbdbd;
    border-radius: 6px;
    padding: 8px 24px;
    font-weight: bold;
    font-size: 15px;
    min-width: 120px;
}
QPushButton#Qpush_btn_close:hover {
    background-color: #bdbdbd;
    border-color: #9e9e9e;
    color: #1a237e;
}
QPushButton#Qpush_btn_close:pressed {
    background-color: #9e9e9e;
    border-color: #757575;
    color: #fff;
}






